{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Shared Renovate preset",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    ":semanticCommits",
    ":semanticCommitTypeAll(fix)"
  ],
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": false,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group all non-major updates",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch",
      "automerge": true
    },
    {
      "description": "Auto-merge dev dependencies",
      "matchDepTypes": ["devDependencies"],
      "automerge": true
    },
    {
      "description": "Pin GitHub Actions digests for supply chain security",
      "matchManagers": ["github-actions"],
      "pinDigests": true
    },
    {
      "description": "Group Rust crate updates",
      "matchManagers": ["cargo"],
      "groupName": "rust dependencies"
    },
    {
      "description": "Group Python dependency updates",
      "matchManagers": ["pip_requirements", "pip-compile", "pep621"],
      "groupName": "python dependencies"
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
